{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://*/*",
      "https://*/*",
      "http://localhost:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default"
  ]
}
