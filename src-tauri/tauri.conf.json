{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prisma",
  "version": "1.1.2",
  "identifier": "com.prisma.desktop",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Prisma",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://prisma.ws"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "macos-info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzMUFFMkRDMTVBNjM2QkQKUldTOU5xWVYzT0lhd3k3dkFjMkdHZG1SZlNzZnZTS1g4WTYvTmFldkY3WnBUYlZSdEVWeVkrKzEK",
      "endpoints": [
        "https://github.com/Sheinices/prisma-desk/releases/latest/download/latest.json"
      ]
    }
  }
}
